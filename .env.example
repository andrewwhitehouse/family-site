# Google OAuth sign-in — copy to .env for local dev (.env is gitignored).
# On Scalingo, set these as environment variables instead.

# From the Google Cloud Console OAuth client (see README).
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxx

# Must exactly match an Authorised redirect URI on the OAuth client.
# Local dev default is http://localhost:3000/oauth/callback (can be omitted locally).
OAUTH_REDIRECT_URI=http://localhost:3000/oauth/callback

# Exactly 16 characters — the AES-128 key that encrypts the session cookie.
# Generate one:  head -c 16 /dev/urandom | base64 | cut -c1-16
SESSION_SECRET=change-me-16char

# The Workspace domain allowed to sign in. Defaults to whitehouse.org.uk.
ALLOWED_DOMAIN=whitehouse.org.uk

# Comma-separated emails granted the admin role (optional).
ADMIN_EMAILS=andrew@whitehouse.org.uk
